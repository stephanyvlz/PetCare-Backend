  "components": {
    "schemas": {
      "AppointmentDto": {
        "required": [
          "id_appointment",
          "user_name",
          "pet_name",
          "veterinarian_name",
          "date",
          "service",
          "cost",
          "status"
        ],
        "type": "object",
        "properties": {
          "id_appointment": {
            "type": "string",
            "format": "uuid"
          },
          "user_name": {
            "type": "string"
          },
          "pet_name": {
            "type": "string"
          },
          "veterinarian_name": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "service": {
            "type": "string"
          },
          "cost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CreateAppointmentDto": {
        "required": [
          "id_user",
          "id_pet",
          "id_clinic",
          "id_veterinarian",
          "appointment_date",
          "service",
          "cost"
        ],
        "type": "object",
        "properties": {
          "id_user": {
            "type": "string",
            "format": "uuid"
          },
          "id_pet": {
            "type": "string",
            "format": "uuid"
          },
          "id_clinic": {
            "type": "string",
            "format": "uuid"
          },
          "id_veterinarian": {
            "type": "string",
            "format": "uuid"
          },
          "appointment_date": {
            "type": "string",
            "format": "date-time"
          },
          "service": {
            "type": "string"
          },
          "cost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateClinicDto": {
        "required": [
          "name",
          "location",
          "schedule"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "schedule": {
            "type": "string"
          }
        }
      },
      "CreateConsultationDto": {
        "required": [
          "id_consultation",
          "id_appointment",
          "diagnosis",
          "observations"
        ],
        "type": "object",
        "properties": {
          "id_consultation": {
            "type": "string",
            "format": "uuid"
          },
          "id_appointment": {
            "type": "string",
            "format": "uuid"
          },
          "diagnosis": {
            "type": "string"
          },
          "observations": {
            "type": "string"
          }
        }
      },
      "CreatePetDto": {
        "required": [
          "name",
          "breed",
          "weight",
          "age"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "breed": {
            "type": "string"
          },
          "weight": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "age": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "CreateTreatmentDto": {
        "required": [
          "id_consultation",
          "medication",
          "dosage",
          "duration",
          "cost"
        ],
        "type": "object",
        "properties": {
          "id_consultation": {
            "type": "string",
            "format": "uuid"
          },
          "medication": {
            "type": "string"
          },
          "dosage": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          },
          "cost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterDto": {
        "required": [
          "name",
          "email",
          "password",
          "id_role",
          "phone",
          "id_clinic"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "id_role": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "phone": {
            "type": [
              "null",
              "string"
            ]
          },
          "id_clinic": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "UpdateUserDto": {
        "required": [
          "name",
          "email",
          "phone",
          "password",
          "id_clinic"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": [
              "null",
              "string"
            ]
