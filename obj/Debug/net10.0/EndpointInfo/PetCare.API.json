  "components": {
    "schemas": {
      "CambiarEstadoDto": {
        "required": [
          "estado"
        ],
        "type": "object",
        "properties": {
          "estado": {
            "type": "string"
          }
        }
      },
      "CreateCitaDto": {
        "required": [
          "idUsuario",
          "idMascota",
          "idClinica",
          "idVeterinario",
          "fecha",
          "servicio",
          "costo"
        ],
        "type": "object",
        "properties": {
          "idUsuario": {
            "type": "string",
            "format": "uuid"
          },
          "idMascota": {
            "type": "string",
            "format": "uuid"
          },
          "idClinica": {
            "type": "string",
            "format": "uuid"
          },
          "idVeterinario": {
            "type": "string",
            "format": "uuid"
          },
          "fecha": {
            "type": "string",
            "format": "date-time"
          },
          "servicio": {
            "type": "string"
          },
          "costo": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateConsultaDto": {
        "required": [
          "idCita",
          "diagnostico",
          "observaciones"
        ],
        "type": "object",
        "properties": {
          "idCita": {
            "type": "string",
            "format": "uuid"
          },
          "diagnostico": {
            "type": "string"
          },
          "observaciones": {
            "type": "string"
          }
        }
      },
      "CreateMascotaDto": {
        "required": [
          "nombre",
          "raza",
          "peso",
          "edad"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "raza": {
            "type": "string"
          },
          "peso": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "edad": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "CreateTratamientoDto": {
        "required": [
          "idConsulta",
          "medicamento",
          "dosis",
          "plazo",
          "costo"
        ],
        "type": "object",
        "properties": {
          "idConsulta": {
            "type": "string",
            "format": "uuid"
          },
          "medicamento": {
            "type": "string"
          },
          "dosis": {
            "type": "string"
          },
          "plazo": {
            "type": "string"
          },
          "costo": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "LoginDto": {
        "required": [
          "correo",
          "password"
        ],
        "type": "object",
        "properties": {
          "correo": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterDto": {
        "required": [
          "nombre",
          "correo",
          "password",
          "rolId"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "correo": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "rolId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "UpdateUsuarioDto": {
        "required": [
          "nombre",
          "correo"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "correo": {
            "type": "string"
          }
        }
      }
    }
